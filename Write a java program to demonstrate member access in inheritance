class Parent
{
    int x = 10;
}

class Child extends Parent
{
    int y = 20;

    void display()
    {
        System.out.println("x = " + x);
        System.out.println("y = " + y);
    }
}

class InheritanceDemo
{
    public static void main(String args[])
    {
        Child c = new Child();
        c.display();
    }
}
