class OverloadMethod
{
    void add(int a,int b)
    {
        System.out.println("Sum = " + (a+b));
    }

    void add(int a,int b,int c)
    {
        System.out.println("Sum = " + (a+b+c));
    }

    public static void main(String args[])
    {
        OverloadMethod obj = new OverloadMethod();

        obj.add(10,20);
        obj.add(10,20,30);
    }
}
